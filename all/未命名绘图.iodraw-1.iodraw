        <mxCell id="QCrLkjZZ-Hu-HGawvUhz-5" value="" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Times New Roman;" vertex="1" parent="1">
          <mxGeometry x="122" y="127" width="1051" height="664" as="geometry" />
        </mxCell>
        <mxCell id="QCrLkjZZ-Hu-HGawvUhz-12" value="&lt;h1 style=&quot;margin-top: 0px; font-size: 19px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;User&lt;/h1&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;Please analyze the object in the provided images&lt;br&gt;and merge the SAM candidate masks into final articulated semantic parts.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;&amp;nbsp;Inputs:&lt;br&gt;1. Original RGB image.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;2. SAM segmentation overview image.&lt;br&gt;3. Indexed SAM mask overview image,where each candidate region has a unique mask_id.&lt;/font&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Times New Roman;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeColor=default;fillColor=default;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="134" y="417" width="1024" height="162" as="geometry" />
        </mxCell>
        <mxCell id="QCrLkjZZ-Hu-HGawvUhz-7" value="" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#9999FF;strokeColor=#6c8ebf;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" vertex="1" parent="1">
          <mxGeometry x="142" y="419" width="31" height="38" as="geometry" />
        </mxCell>
        <mxCell id="QCrLkjZZ-Hu-HGawvUhz-10" value="&lt;h1 style=&quot;margin-top: 0px; font-size: 19px;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;System&lt;/font&gt;&lt;/span&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; font-size: 15px;&quot;&gt;&lt;font style=&quot;font-weight: normal; font-size: 15px;&quot;&gt;Role:You are an expert vision-language parser for articulated objects&lt;/font&gt;&lt;font style=&quot;font-size: 15px; font-weight: normal;&quot;&gt;.&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;background-color: initial; font-weight: normal;&quot;&gt;Task:Analyze an object image with SAM-generated candidate masks,&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;and merge the candidate masks into articulated semantic parts.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-weight: normal;&quot;&gt;Allowed labels:&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;base, door, knob, handle, drawer, tray&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;Structural constraints:&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;1. There must be exactly one &quot;base&quot; part,&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;&quot;tray&quot; can only appear in microwaves.&amp;nbsp;Each &quot;handle&quot; or &quot;knob&quot; must be attached to a &quot;door&quot; or a &quot;drawer&quot;.&amp;nbsp;Each &quot;door&quot; can have at most one &quot;handle&quot; or &quot;knob&quot;.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-weight: normal;&quot;&gt;2.Each candidate mask can belong to only one final part.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-weight: normal;&quot;&gt;3. Background regions should not be assigned to any part.&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;Output format:&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;Return only a valid JSON object:{&quot;parts&quot;: [{&quot;part_id&quot;: &quot;&amp;lt;int&amp;gt;&quot;,&quot;part_label&quot;: &quot;&amp;lt;semantic_label&amp;gt;&quot;,&quot;mask_ids&quot;: [&quot;&amp;lt;mask_id&amp;gt;&quot;, &quot;...&quot;],&quot;attached_to_part_id&quot;: &quot;&amp;lt;part_id|null&amp;gt;&quot;},...]}&lt;/span&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Times New Roman;glass=0;strokeWidth=1;fillColor=default;strokeColor=default;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="134" y="135" width="1028" height="266" as="geometry" />
        </mxCell>
        <mxCell id="QCrLkjZZ-Hu-HGawvUhz-18" value="&lt;h1 style=&quot;margin-top: 0px; font-size: 19px;&quot;&gt;&lt;span style=&quot;font-size: 15px; background-color: initial; font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; font-size: 19px;&quot;&gt;&lt;span style=&quot;font-size: 15px; background-color: initial; font-weight: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; font-size: 19px;&quot;&gt;&lt;img style=&quot;background-color: initial; font-size: 12px; font-weight: normal;&quot; alt=&quot;&quot; src=&quot;data:image/png;base64,&quot;&gt;&lt;img height=&quot;332&quot; width=&quot;661&quot; src=&quot;data:image/png;base64,&quot;&gt;&lt;span style=&quot;font-size: 15px; background-color: initial; font-weight: normal;&quot;&gt;&amp;nbsp;Inputs:&lt;/span&gt;&lt;/h1&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;1. Original RGB image.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;2. SAM segmentation overview image.&lt;br&gt;3. Indexed SAM mask overview image,where each candidate region has a unique mask_id.&lt;/font&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Times New Roman;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeColor=default;fillColor=default;shadow=1;" vertex="1" parent="1">
